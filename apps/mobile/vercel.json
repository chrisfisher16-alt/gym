{
  "installCommand": "echo 'skip'",
  "buildCommand": null,
  "outputDirectory": "dist",
  "functions": {
    "api/*.js": {
      "includeFiles": "api/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
